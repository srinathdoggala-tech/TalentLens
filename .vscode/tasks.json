{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Backend (FastAPI)",
            "type": "shell",
            "command": ".\\backend\\venv\\Scripts\\python -m uvicorn backend.main:app --host 127.0.0.1 --port 8000",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Start Frontend (Next.js)",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run TalentLens (Both)",
            "dependsOn": [
                "Start Backend (FastAPI)",
                "Start Frontend (Next.js)"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
